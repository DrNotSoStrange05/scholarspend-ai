# ScholarSpend AI - Environment Configuration Example
# Copy this to `.env` and fill in your values

# ─── Database ────────────────────────────────────────────────────
# Local development (SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./scholarspend_dev.db

# PostgreSQL (Docker Compose)
# DATABASE_URL=postgresql+asyncpg://scholar:scholar_secret@db:5432/scholarspend

# PostgreSQL (Railway - auto-provided)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# PostgreSQL (Render - auto-provided)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── FastAPI ─────────────────────────────────────────────────────
# Port for local development
PORT=8000

# ─── CORS (for Flutter app) ──────────────────────────────────────
# Local development
ALLOWED_ORIGINS=http://localhost:8081,http://10.0.2.2:8000

# Production (Railway)
ALLOWED_ORIGINS=https://your-railway-url.up.railway.app

# ─── Flutter App Configuration ───────────────────────────────────
# Backend API Base URL
# Local: http://192.168.x.x:8000/api (for physical device)
# Cloud: https://your-deployed-url.app/api

# Update in: flutter_app/lib/services/api_service.dart
# static const String _baseUrl = 'https://your-backend-url.app/api';
